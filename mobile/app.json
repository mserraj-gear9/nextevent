{
  "expo": {
    "name": "NextEvent",
    "slug": "nextevent",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "nextevent",
    "plugins": ["expo-router", "expo-secure-store", ["expo-camera", { "cameraPermission": "Allow NextEvent to access your camera for QR scanning." }]],
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#050709"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": { "supportsTablet": true, "bundleIdentifier": "com.nextevent.app" },
    "android": { "adaptiveIcon": { "foregroundImage": "./assets/adaptive-icon.png", "backgroundColor": "#050709" }, "package": "com.nextevent.app", "permissions": ["android.permission.CAMERA"] }
  }
}
